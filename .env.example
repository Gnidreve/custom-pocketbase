# Google / Firebase
GOOGLE_PROJECT_ID=your-google-project-id
GOOGLE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-google-project-id.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Optional override
# GOOGLE_TOKEN_URL=https://oauth2.googleapis.com/token

# Alternative option A: JSON file path
# GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/firebase-service-account.json

# Alternative option B: full service account JSON in one line
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-google-project-id"}
